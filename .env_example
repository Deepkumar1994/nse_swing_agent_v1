# Copy this file to .env and fill in your actual API keys
# NEVER commit the actual .env file to Git

# Anthropic API (Claude AI brain)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Tavily Search API (for news)
# Get from: https://tavily.com (free tier available)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# Telegram Bot Token
# Get from: @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID
# Get by sending a message to your bot then visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=xxxxxxxxxx
